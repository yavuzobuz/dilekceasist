# Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here
# Optional: separate key for query expansion if you want to isolate that traffic
GEMINI_LEGAL_QUERY_EXPANSION_API_KEY=
# Optional: separate key for embedding rerank traffic
GEMINI_EMBEDDING_API_KEY=
# Optional: separate model for legal precedent search planning
# Default fallback in code: gemini-3-flash-preview
GEMINI_LEGAL_SEARCH_MODEL_NAME=gemini-3-flash-preview
# Query expansion uses a cheaper text-generation model by default
GEMINI_LEGAL_QUERY_EXPANSION_MODEL_NAME=gemini-2.5-flash
# Embedding rerank uses the dedicated embedding model
GEMINI_EMBEDDING_MODEL_NAME=text-embedding-004
# Stripe Billing (server side)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
APP_BASE_URL=http://localhost:3000
# Legal search backend selection
# simple = direct Bedesten (default)
# mcp = use Yargi MCP as primary backend
LEGAL_PRIMARY_BACKEND=simple
# Single canonical Yargi MCP endpoint used by the app.
# Local development example: http://127.0.0.1:8000/mcp/
# Production can point to the remote MCP endpoint or Cloud Run proxy.
YARGI_MCP_URL=https://yargimcp.fastmcp.app/mcp/
# Optional remote Karakazi/Playwright endpoint. If omitted, /mcp/ is rewritten to /api/karakazi-search.
KARAKAZI_REMOTE_URL=
# Keep remote document fetching off by default; it is heavier and can 503 on Cloud Run.
KARAKAZI_REMOTE_FETCH_DOCUMENTS=0
# Keep legacy/simple fallback enabled unless you intentionally want hard fail
LEGAL_SIMPLE_ALLOW_LEGACY_FALLBACK=1
