# Backend Server Configuration
# Rename this file to .env and fill in your values
# REQUIRED: Gemini API Key for AI features
GEMINI_API_KEY=AIzr...
# OPTIONAL: Separate API key for query expansion traffic
GEMINI_LEGAL_QUERY_EXPANSION_API_KEY=
# OPTIONAL: Separate API key for embedding traffic
GEMINI_EMBEDDING_API_KEY=
# OPTIONAL: Separate model for legal precedent search planning
# If empty, backend falls back to gemini-3-flash-preview for this flow only
GEMINI_LEGAL_SEARCH_MODEL_NAME=gemini-3-flash-preview
# OPTIONAL: Query expansion model (default: gemini-2.5-flash)
GEMINI_LEGAL_QUERY_EXPANSION_MODEL_NAME=gemini-2.5-flash
# OPTIONAL: Embedding model (default: text-embedding-004)
GEMINI_EMBEDDING_MODEL_NAME=text-embedding-004
# OPTIONAL: Frontend URL for CORS (default allowed: localhost:3000)
FRONTEND_URL=http://localhost:5173
# OPTIONAL: Additional allowed CORS origins (comma-separated)
# Example: CORS_ORIGINS=http://localhost:8080,https://app.example.com
CORS_ORIGINS=
# OPTIONAL: Server Port (default: 3001)
PORT=3001
# REQUIRED: Supabase Configuration (if used by backend directly)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# REQUIRED for Stripe billing (paid plan checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...
# REQUIRED for Stripe webhook signature verification
STRIPE_WEBHOOK_SECRET=whsec_...
# REQUIRED in production (frontend base URL used for checkout success/cancel redirects)
# Example: https://dilekai.com
APP_BASE_URL=http://localhost:3000
# Legal search backend selection
# simple = direct Bedesten (default)
# mcp = use Yargi MCP as primary backend
LEGAL_PRIMARY_BACKEND=simple
# Optional self-hosted Yargi MCP endpoint
# Example local ASGI server: http://127.0.0.1:8000/mcp/
YARGI_MCP_URL=https://yargimcp.fastmcp.app/mcp/
# Keep fallback on while testing
LEGAL_SIMPLE_ALLOW_LEGACY_FALLBACK=1
